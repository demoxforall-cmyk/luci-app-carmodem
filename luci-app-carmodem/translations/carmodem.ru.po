msgstr "AT-консоль"

msgid "AT+CEREG? — network registration"
msgstr "AT+CEREG? — регистрация в сети"

msgid "AT+CFUN=1,1 — reboot modem (apply changes)"
msgstr "AT+CFUN=1,1 — перезагрузить модем (применить изменения)"

msgid "AT+CFUN? — modem mode"
msgstr "AT+CFUN? — режим модема"

