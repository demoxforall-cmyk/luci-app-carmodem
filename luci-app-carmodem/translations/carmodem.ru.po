msgstr "AT+QCAINFO — агрегация несущих (CA)"

msgid "AT+QCCID — SIM card ICCID"
msgstr "AT+QCCID — ICCID SIM-карты"

msgid "AT+QCFG=\"data_interface\" — data path: 0 USB / 1 PCIe"
msgstr "AT+QCFG=\"data_interface\" — канал данных: 0 USB / 1 PCIe"

msgid "AT+QCFG=\"data_interface\",0,0 — data path USB (reboot)"
msgstr "AT+QCFG=\"data_interface\",0,0 — канал данных USB (ребут)"

msgid "AT+QCFG=\"data_interface\",1,0 — data path PCIe (reboot)"
msgstr "AT+QCFG=\"data_interface\",1,0 — канал данных PCIe (ребут)"

msgid "AT+QCFG=\"usbnet\" — USB net mode (0 QMI · 1 ECM · 2 MBIM · 3 RNDIS · 5 NCM)"
msgstr "AT+QCFG=\"usbnet\" — режим USB-сети (0 QMI · 1 ECM · 2 MBIM · 3 RNDIS · 5 NCM)"

msgid "AT+QCFG=\"usbnet\",0 — switch to QMI/RMNET (reboot)"
msgstr "AT+QCFG=\"usbnet\",0 — переключить на QMI/RMNET (ребут)"

msgid "AT+QCFG=\"usbnet\",1 — switch to ECM (reboot)"
msgstr "AT+QCFG=\"usbnet\",1 — переключить на ECM (ребут)"

msgid "AT+QCFG=\"usbnet\",2 — switch to MBIM (reboot)"
msgstr "AT+QCFG=\"usbnet\",2 — переключить на MBIM (ребут)"

msgid "AT+QCFG=\"usbnet\",3 — switch to RNDIS (reboot)"
msgstr "AT+QCFG=\"usbnet\",3 — переключить на RNDIS (ребут)"

msgid "AT+QENG=\"servingcell\" — serving cell"
msgstr "AT+QENG=\"servingcell\" — ведущая сота"

msgid "AT+QNWINFO — network: tech / band / channel"
msgstr "AT+QNWINFO — сеть: технология / band / канал"

msgid "AT+QNWPREFCFG=\"lte_band\" — allowed LTE bands"
msgstr "AT+QNWPREFCFG=\"lte_band\" — разрешённые LTE band"

msgid "AT+QNWPREFCFG=\"mode_pref\" — preferred RAT"
msgstr "AT+QNWPREFCFG=\"mode_pref\" — предпочтительный RAT"

msgid "AT+QNWPREFCFG=\"nr5g_band\" — allowed NR bands"
msgstr "AT+QNWPREFCFG=\"nr5g_band\" — разрешённые NR band"

msgid "AT+QRSRP — RSRP per antenna"
msgstr "AT+QRSRP — RSRP по антеннам"

msgid "AT+QRSRQ — RSRQ per antenna"
msgstr "AT+QRSRQ — RSRQ по антеннам"

msgid "AT+QSINR — SINR per antenna"
msgstr "AT+QSINR — SINR по антеннам"

msgid "AT+QTEMP — modem temperature"
msgstr "AT+QTEMP — температура модема"

msgid "AT+QUIMSLOT? — active SIM slot"
msgstr "AT+QUIMSLOT? — активный слот SIM"

