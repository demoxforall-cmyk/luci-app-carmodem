msgstr "AT+CGDCONT? — PDP-контексты / APN"

msgid "AT+COPS? — current operator"
msgstr "AT+COPS? — текущий оператор"

msgid "AT+CPIN? — SIM / PIN status"
msgstr "AT+CPIN? — статус SIM / PIN"

