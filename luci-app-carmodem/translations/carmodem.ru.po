msgstr "Интернет"

msgid "L1 threshold (cycles)"
msgstr "Порог L1 (циклы)"

msgid "L1 · Reconnect interface"
msgstr "L1 · Реконнект интерфейса"

msgid "L2 threshold (cycles)"
msgstr "Порог L2 (циклы)"

msgid "L2 · Reset modem"
msgstr "L2 · Reset модема"

msgid "L3 reboots the whole router. Kept safe: only when connected (bearer up) but no data, and once per episode."
msgstr "L3 перезагружает весь роутер. Защита: только когда модем подключён (bearer поднят), но данных нет, и 1 раз за эпизод."

msgid "L3 threshold (cycles)"
msgstr "Порог L3 (циклы)"

msgid "L3 · Reboot router"
msgstr "L3 · Перезагрузка роутера"

